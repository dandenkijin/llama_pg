# =============================================================================
# Qwen3.6 35B Configuration for llama-cpp-turboquant
# REPO_URL=https://github.com/johndpope/llama-cpp-turboquant.git
# =============================================================================
MODEL_FILE=Huihui-Qwen3.6-35B-A3B-abliterated.Q4_K_M.gguf
MODEL_DIR=/root/models

# =============================================================================
# Performance Settings 
# =============================================================================
N_CTX=256144
N_GPU_LAYERS=41
N_THREADS=6
N_CPU_MOE=36

# =============================================================================
# Cache & Attention (TurboQuant flags)
# =============================================================================
CACHE_TYPE_K=iso3
CACHE_TYPE_V=iso3
FLASH_ATTN=true

# =============================================================================
# Rope & Context
# =============================================================================
ROPE_SCALING=yarn
ROPE_SCALE=8.0

# =============================================================================
# Runtime flags (true/false)
# =============================================================================
NO_MMAP=true
MLOCK=true
JINJA=true
NO_WARMUP=true

# =============================================================================
# Speculative decoding
# =============================================================================
SPEC_TYPE=none
